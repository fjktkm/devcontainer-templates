{
    "id": "latex",
    "version": "1.0.0",
    "name": "LaTeX (TeX Live)",
    "description": "A Dev Container for editing LaTeX documents with TeX Live. Supports pdfLaTeX, LuaLaTeX, pLaTeX, and upLaTeX engines including Japanese typesetting.",
    "documentationURL": "https://github.com/fjktkm/devcontainer-templates/tree/main/src/latex",
    "licenseURL": "https://github.com/fjktkm/devcontainer-templates/blob/main/LICENSE",
    "optionalPaths": [
        ".github/*",
        ".vscode/*",
        "lualatex/*",
        "pdflatex/*",
        "platex/*",
        "uplatex/*",
        ".gitattributes",
        ".gitignore"
    ],
    "platforms": [
        "Any"
    ],
    "keywords": [
        "latex",
        "tex",
        "tex-live",
        "typesetting",
        "japanese"
    ]
}
